<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 局域网 HTTP 明文（WebView 载入 http://电脑IP:3000） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
